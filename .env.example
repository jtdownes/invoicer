# Downes Capital Postgres (port 5440 on host, 5432 in container)
DC_DB_HOST=downes-capital-db
DC_DB_PORT=5432
DC_DB_NAME=invoicer
DC_DB_USER=admin
DC_DB_PASSWORD=your_db_password_here

# Auth
JWT_SECRET=generate-a-strong-random-string-here

# First-ever invite token — used to bootstrap the admin account.
# On startup, if no users exist, this token is inserted as a valid 30-day invite.
# Visit /register?invite=<this-token> to create the first admin, then update role to admin in DB.
# Leave blank after first user is created.
FIRST_INVITE_TOKEN=

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://192.168.1.10:7862,https://invoicer.jtdownes.com
